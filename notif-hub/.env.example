# Anthropic API Key (必須)
# https://console.anthropic.com/settings/keys から取得
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# Phase 1 はこれだけでOK（モックで動作確認）

# === Phase 2 以降で必要 ===

# 各 MCP サーバー用の OAuth トークン
# claude.ai のコネクター設定で取得済みのものを使う
# 参考: https://docs.claude.com/en/docs/build-with-claude/mcp

GMAIL_OAUTH_TOKEN=
SLACK_OAUTH_TOKEN=
NOTION_OAUTH_TOKEN=
FIGMA_OAUTH_TOKEN=

# Phase（環境切替用）: 1=モック, 3=Gmail実接続
PHASE=1

# Phase 3 だけ Gmail を有効にする場合（PHASE=1 でも単独で有効化可能）
USE_REAL_GMAIL=false
